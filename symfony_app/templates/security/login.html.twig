{% extends 'base.html.twig' %}

{% block title %}Вход | Mixas Art Works{% endblock %}

{% block body %}
    <section class="mx-auto p-4 rounded-4 bg-white shadow-sm" style="max-width: 480px;">
        <h1 class="h3 mb-3">Вход администратора Mixas Art Works</h1>

        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="mb-3">
                <label class="form-label" for="username">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
            </div>
            <div class="mb-3">
                <label class="form-label" for="password">Пароль</label>
                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="btn btn-dark w-100" type="submit">Войти</button>
        </form>
        <p class="small text-muted mt-3 mb-0">Тестовый доступ: admin@mixas.local / Admin123!</p>
    </section>
{% endblock %}
