{% extends 'base.html.twig' %}

{% block title %}{{ page.title }} | Mixas Art Works{% endblock %}

{% block body %}
    <section class="p-4 rounded-4 bg-white shadow-sm mb-4">
        <h1 class="h2 mb-3">{{ page.title }}</h1>
        <div class="page-content mb-0">{{ page.content|raw }}</div>
    </section>

    <section class="row g-4">
        {% for work in works %}
            <div class="col-sm-6 col-lg-4">
                {% set themeLabel = work.visualTheme == 'sons-of-horus' ? 'Horus Heresy' : (work.visualTheme == 'stormcast' ? 'Age of Sigmar' : 'Warhammer 40k') %}
                <article class="card work-card work-card--{{ work.visualTheme }} h-100 border-0 shadow-sm">
                    {% set cover = work.coverPhoto %}
                    {% if cover %}
                        <img src="{{ media_url(cover.imagePath) }}" class="card-img-top gallery-thumb enlargeable-image" alt="{{ work.title }}" data-enlargeable data-fullsrc="{{ media_url(cover.imagePath) }}">
                    {% endif %}
                    <div class="card-body">
                        <span class="theme-chip theme-chip--{{ work.visualTheme }}">{{ themeLabel }}</span>
                        <h2 class="h6 mb-2">{{ work.title }}</h2>
                        <p class="small text-muted mb-3">{{ work.description|striptags|slice(0, 120) }}{% if work.description|striptags|length > 120 %}...{% endif %}</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge text-bg-light">{{ work.photoCount }} фото</span>
                            <a href="{{ path('app_work_show', {slug: work.slug}) }}" class="btn btn-sm btn-outline-dark">Смотреть</a>
                        </div>
                    </div>
                </article>
            </div>
        {% else %}
            <p class="text-muted">В галерее пока нет опубликованных работ.</p>
        {% endfor %}
    </section>
{% endblock %}
