{% extends 'base.html.twig' %}

{% block title %}{{ page.title }} | Mixas Art Works{% endblock %}

{% block body %}
    <section class="p-4 rounded-4 bg-white shadow-sm mb-4">
        <h1 class="h2 mb-3">{{ page.title }}</h1>
        <div class="page-content mb-0">{{ page.content|raw }}</div>
    </section>

    <section class="p-4 rounded-4 bg-white shadow-sm">
        <h2 class="h4 mb-3">Форма обратной связи</h2>
        {{ form_start(form, {'attr': {'class': 'feedback-form'}}) }}
            <div class="row g-3">
                <div class="col-md-6">
                    {{ form_row(form.name) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.email) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.message) }}
                </div>
            </div>
            <button class="btn btn-dark mt-3" type="submit">Отправить</button>
        {{ form_end(form) }}
    </section>
{% endblock %}
