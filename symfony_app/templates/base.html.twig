<!DOCTYPE html>
<html lang="ru">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Mixas Art Works{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'%3E%3Ctext y='0.9em' font-size='90'%3E%F0%9F%8E%A8%3C/text%3E%3C/svg%3E">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% set navItems = navigation_pages() %}
        <header class="site-header border-bottom">
            <div class="container py-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
                <a href="{{ path('app_home') }}" class="brand text-decoration-none">Mixas Art Works</a>
                <nav class="d-flex flex-wrap align-items-center gap-2">
                    {% for item in navItems %}
                        <a class="nav-link-custom" href="{{ item.url }}">{{ item.label }}</a>
                    {% endfor %}

                    {% if is_granted('ROLE_ADMIN') %}
                        <a class="nav-link-custom nav-link-admin" href="{{ path('admin_page_index') }}">Админ: страницы</a>
                        <a class="nav-link-custom nav-link-admin" href="{{ path('admin_work_index') }}">Админ: работы</a>
                        <a class="nav-link-custom nav-link-admin" href="{{ path('admin_work_photo_index') }}">Админ: фото</a>
                        <a class="btn btn-sm btn-outline-dark" href="{{ path('app_logout') }}">Выйти</a>
                    {% else %}
                        <a class="btn btn-sm btn-dark" href="{{ path('app_login') }}">Вход</a>
                    {% endif %}
                </nav>
            </div>
        </header>

        <main class="container py-4">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} mb-3">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="site-footer border-top mt-4">
            <div class="container py-3 text-center small text-muted">
                Mixas Art Works
            </div>
        </footer>

        <div id="image-lightbox" class="image-lightbox" hidden aria-hidden="true">
            <button type="button" class="image-lightbox__backdrop" data-lightbox-close aria-label="Закрыть"></button>
            <div class="image-lightbox__content" role="dialog" aria-modal="true">
                <button type="button" class="image-lightbox__close btn-close btn-close-white" data-lightbox-close aria-label="Закрыть"></button>
                <img id="image-lightbox-image" class="image-lightbox__image" src="" alt="">
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    </body>
</html>
