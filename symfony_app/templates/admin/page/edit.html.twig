{% extends 'base.html.twig' %}

{% block title %}Редактирование страницы | Админ{% endblock %}

{% block body %}
    <section class="p-4 rounded-4 bg-white shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Редактирование: {{ page.title }}</h1>
            <a class="btn btn-outline-dark" href="{{ path('admin_page_index') }}">К списку</a>
        </div>

        {% if page.systemKey %}
            <div class="alert alert-info">Это системная страница ({{ page.systemKey }}). Удаление запрещено.</div>
        {% endif %}

        {{ include('admin/page/_form.html.twig', {form: form, button_label: 'Сохранить'}) }}
    </section>
{% endblock %}
