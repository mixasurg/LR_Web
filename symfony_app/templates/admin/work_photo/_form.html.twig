{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-8">
            {{ form_row(form.work) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.sortOrder) }}
        </div>
        <div class="col-12">
            {{ form_row(form.imagePath) }}
        </div>
        <div class="col-12">
            {{ form_row(form.caption) }}
        </div>
        <div class="col-12">
            {{ form_row(form.isPublished) }}
        </div>
    </div>
    <button class="btn btn-dark mt-3">{{ button_label|default('Сохранить') }}</button>
{{ form_end(form) }}
